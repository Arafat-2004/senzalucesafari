{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [ "dom", "dom.iterable", "esnext" ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [ "./src/*" ]
    },
    "typeRoots": [ "./node_modules/@types" ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "src/generated/prisma/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "migrate-*.ts",
    "migrate-*.js",
    "run-migration.js",
    "test-db-connection.mjs",
    "test-setup.js",
    "verify-*.js",
    "verify-*.mjs",
    "generate-*.js",
    "scripts/**/*.ts",
    "scripts/**/*.js",
    "src/generated/prisma/internal/**"
  ]
}
