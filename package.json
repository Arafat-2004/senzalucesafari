{
  "name": "senzalucesafaris",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=3072 next dev --webpack -p 3000 -H 0.0.0.0",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});console.log('.next cleaned')\"",
    "dev:noturbo": "cross-env NODE_OPTIONS=--max-old-space-size=3072 next dev --no-turbopack -p 3000 -H 0.0.0.0",
    "dev:safe": "cross-env NODE_OPTIONS=--max-old-space-size=2048 next dev -p 3000",
    "build": "node --max-old-space-size=3072 node_modules/next/dist/bin/next build --webpack",
    "start": "next start -p 3000",
    "start:guard": "powershell -ExecutionPolicy Bypass -File scripts/start-dev.ps1",
    "lint": "eslint",
    "db:migrate:supabase": "tsx scripts/migrate-source-to-supabase.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:rbac": "tsx prisma/seed-rbac.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:mfa": "playwright test --grep @mfa",
    "test:stress": "node scripts/mfa-stress.js",
    "test:bruteforce": "node scripts/mfa-stress.js bruteforce",
    "test:race": "node scripts/mfa-stress.js race",
    "test:smoke": "node scripts/smoke-tests.js",
    "health": "node scripts/health-check.js",
    "validate:env": "node -e \"require('./src/lib/env.js')\"",
    "predeploy": "npm run test:smoke && npm run build"
  },
