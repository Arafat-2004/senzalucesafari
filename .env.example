# ============================================
# Senza Luce Safaris - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---- Database (Supabase PostgreSQL via Prisma) ----

# Connection pooling URL (used by Prisma Client at runtime)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (used by Prisma Migrate for schema changes)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ---- Supabase ----

# Public Supabase project URL and anon key (safe for browser)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# ---- App ----

NODE_ENV=development
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Security: MFA Encryption ----
# REQUIRED: Generate a secure 32+ character key for MFA secrets
# Run: openssl rand -base64 32
MFA_ENCRYPTION_KEY=""

# ---- Installable App & Web Push ----
# Generate a matching public/private pair with: npm run push:generate-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
# A monitored contact URI required by the Web Push protocol.
VAPID_SUBJECT="mailto:admin@example.com"

# ---- Rate Limiting (Upstash Redis) ----
# Optional but recommended for production rate limiting
# Get from https://upstash.com/ after creating a Redis database
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# ---- Media Storage ----
# Choose storage provider: "supabase" (default) or "cloudinary"
# Cloudinary is recommended for automatic optimization (compression, WebP, CDN)
NEXT_PUBLIC_MEDIA_PROVIDER="supabase"

# Supabase Storage (used when MEDIA_PROVIDER is "supabase")
# Create a bucket named "images" in Supabase dashboard with public access
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET="images"
NEXT_PUBLIC_SUPABASE_STORAGE_FOLDER="uploads"

# Cloudinary (used when MEDIA_PROVIDER is "cloudinary")
# Get from https://cloudinary.com/console/settings/camera
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="ml_default"
NEXT_PUBLIC_CLOUDINARY_FOLDER="senza-luce"

# ---- Deployment (Vercel) ----
# NEXT_PUBLIC_VERCEL_URL=""
# VERCEL_PROJECT_PRODUCTION_URL=""
# Encrypts SMTP passwords and webhook signing secrets stored in the database.
SETTINGS_ENCRYPTION_KEY=
