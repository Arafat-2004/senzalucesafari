# ============================================
# Senza Luce Safaris - Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ---- Database (Supabase PostgreSQL via Prisma) ----

# Connection pooling URL (used by Prisma Client at runtime)
DATABASE_URL="postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-1-eu-north-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (used by Prisma Migrate for schema changes)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ---- Supabase ----

# Public Supabase project URL and anon key (safe for browser)
NEXT_PUBLIC_SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# Supabase project reference ID
SUPABASE_PROJECT_REF=""

# ---- App ----

NODE_ENV=development
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ---- Optional: Third-party tokens ----

# GitHub Personal Access Token (for CI/CD or MCP)
# GITHUB_TOKEN=""

# Figma Access Token (for design integration)
# FIGMA_ACCESS_TOKEN=""

# ---- Sentry (Error Monitoring) ----
# Get from https://sentry.io/ after creating a project
# NEXT_PUBLIC_SENTRY_DSN=""
