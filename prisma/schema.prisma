// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model AppSettings {
  id                String  @id @default(uuid())
  version           Int     @default(1)
  siteTitle         String
  siteUrl           String
  logoUrl           String?
  faviconUrl        String?
  theme             Theme   @default(SYSTEM)
  primaryColor      String?
  timezone          String  @default("UTC")
  currency          String  @default("USD")
  signupEnabled     Boolean @default(true)
  mfaRequired       Boolean @default(false)
  passwordPolicy    Json?
  sessionExpiration Int     @default(60)
  allowedDomains    String[]
  dataRetentionDays Int?
  backupsEnabled    Boolean @default(false)
  backupSchedule    String?
  featureFlags      Json?
  environment       String  @default("production")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

model SettingsAudit {
  id          String  @id @default(uuid())
  timestamp   DateTime @default(now())
  changedBy   String?
  environment String?
  changes     Json
}

model Role {
  id          String @id @default(uuid())
  name        String
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

// ============================================
// SENZA LUCE SAFARIS - COMPLETE DATABASE SCHEMA
// ============================================

// --------------- TOURS & PACKAGES ---------------

model Tour {
  id                String     @id @default(uuid())
  name              String
  slug              String     @unique
  category          String     // e.g., "Wildlife Safari", "Safari & Beach", "Kilimanjaro Trek"
  shortDescription  String     @db.VarChar(500)
  overview          String     @db.Text
  bestFor           String[]   // Target audience
  duration          String     // e.g., "5 days / 4 nights"
  startEnd          String     // e.g., "Arusha"
  highlights        String[]
  itinerary         Json       // Array of day-by-day itinerary
  included          String[]
  excluded          String[]
  imageUrl          String
  priceFrom         Float      // Base price per person (USD)
  rating            Float      @default(0)  // 0-10 scale
  reviewCount       Int        @default(0)
  difficulty        String?    // "Easy", "Moderate", "Challenging"
  isActive          Boolean    @default(true)
  isFeatured        Boolean    @default(false)
  displayOrder      Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  // Relations
  destinations      TourDestination[]
  bookings          Booking[]
  reviews           Review[]
  pricing           TourPricing?
  
  @@map("tours")
  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
}

model TourPricing {
  id                String   @id @default(uuid())
  tourId            String   @unique
  tour              Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  
  // Pricing tiers based on group size
  pricePerPerson2   Float    // 2 people
  pricePerPerson3   Float    // 3 people
  pricePerPerson4   Float    // 4 people
  pricePerPerson5   Float    // 5 people
  pricePerPerson6   Float    // 6 people
  
  // Accommodation supplements
  luxurySupplement  Float    @default(0)
  midRangeSupplement Float   @default(0)
  budgetSupplement  Float    @default(0)
  
  // Discounts
  earlyBirdDiscount Float    @default(0)  // Percentage
  lastMinuteDiscount Float   @default(0)  // Percentage
  
  currency          String   @default("USD")
  updatedAt         DateTime @updatedAt
  
  @@map("tour_pricing")
}

// --------------- DESTINATIONS ---------------

model Destination {
  id                String     @id @default(uuid())
  name              String
  slug              String     @unique
  region            String     // e.g., "Northern Circuit", "Southern Circuit"
  shortDescription  String     @db.VarChar(500)
  whyVisit          String     @db.Text
  fullDescription   String     @db.Text
  distanceFromDarEsSalaam String?
  suggestedItineraries String?
  sampleItineraries Json?
  localTribes       String[]
  
  // Quick Facts
  parkSize          String?
  elevation         String?
  established       String?
  nearestAirport    String?
  distanceFromArusha String?
  recommendedStay   String?
  
  // Wildlife
  bigFive           String[]
  keySpecies        String[]
  birdWatching      Boolean    @default(false)
  uniqueSpecies     String[]
  wildlifeRating    Int        @default(0)  // 1-5
  
  // Best Time to Visit
  bestTimeToGo      String[]
  peakSeason        String?
  lowSeason         String?
  monthlyBreakdown  Json?      // Array of monthly data
  
  // Activities
  activities        Json?      // Array of activities
  
  // Features
  highlights        String[]
  landscape         String?
  ecosystems        String[]
  
  // Accommodations
  accommodations    Json?      // Array of accommodation options
  
  // Getting There
  gettingThere      Json?      // Transport options
  
  // Conservation & Cultural
  conservation      String?    @db.Text
  communityInitiatives String? @db.Text
  culturalContext   String?    @db.Text
  
  // Travel Info
  travelTips        Json?      // Array of tips
  faqs              Json?      // Array of FAQs
  
  // Images
  imageUrl          String
  galleryImages     String[]
  
  // SEO
  metaTitle         String?
  metaDescription   String?
  rawData           Json?
  
  isActive          Boolean    @default(true)
  displayOrder      Int        @default(0)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  // Relations
  tours             TourDestination[]
  
  @@map("destinations")
  @@index([region])
  @@index([isActive])
}

model TourDestination {
  id            String   @id @default(uuid())
  tourId        String
  destinationId String
  tour          Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  
  @@unique([tourId, destinationId])
  @@index([destinationId])
  @@map("tour_destinations")
}

// --------------- ACCOMMODATIONS ---------------

model Accommodation {
  id                String     @id @default(uuid())
  name              String
  slug              String     @unique
  type              String     // "Luxury", "Mid-Range", "Budget", "Camping"
  tier              String?
  location          String
  description       String     @db.Text
  priceRange        String?
  
  // Features
  amenities         String[]
  images            String[]
  bestFor           String[]
  highlights        String[]
  rating            Float      @default(0)  // 1-5
  
  // Pricing
  pricePerNight     String
  currency          String     @default("USD")
  
  // Contact
  website           String?
  email             String?
  phone             String?
  rawData           Json?
  
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  @@map("accommodations")
  @@index([type])
  @@index([location])
  @@index([isActive])
}

// --------------- VEHICLES ---------------

model Vehicle {
  id                String     @id @default(uuid())
  name              String
  type              String?    // Vehicle type from legacy data
  category          String     // "Luxury Safari Vehicle", "Standard Safari Vehicle", etc.
  imageUrl          String
  capacity          String     // Number of passengers
  rating            Float      @default(0)
  reviews           Int        @default(0)
  priceRange        String
  description       String     @db.Text
  
  // Features
  features          String[]   // Pop-up roof, charging ports, etc.
  bestFor           String[]
  specifications    Json
  safetyFeatures    String[]
  safariEquipment   String[]
  interiorImages    String[]
  exteriorImages    String[]
  actionShots       String[]
  images            String[]
  
  // Specifications
  engine            String?
  transmission      String?
  fuelType          String?
  year              Int?
  rawData           Json?
  
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  // Relations
  bookings          Booking[]
  
  @@map("vehicles")
  @@index([category])
  @@index([isActive])
}

// --------------- BOOKINGS ---------------

model Booking {
  id                String         @id @default(uuid())
  bookingRef        String         @unique  // Human-readable reference
  tourId            String
  tour              Tour           @relation(fields: [tourId], references: [id], onDelete: Restrict)
  
  // Customer Info
  firstName         String
  lastName          String
  email             String
  phone             String
  country           String
  countryCode       String?
  
  // Travel Details
  travelDate        DateTime
  endDate           DateTime
  numberOfTravelers Int
  accommodationLevel String        // "luxury", "mid-range", "budget"
  
  // Pricing
  pricePerPerson    Float
  totalPrice        Float
  currency          String         @default("USD")
  depositPaid       Float          @default(0)
  paymentStatus     PaymentStatus  @default(PENDING)
  
  // Booking Status
  status            BookingStatus  @default(PENDING)
  specialRequests   String?        @db.Text
  internalNotes     String?        @db.Text
  
  // Assigned Resources
  vehicleId         String?
  vehicle           Vehicle?       @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  guideId           String?
  guide             Guide?         @relation(fields: [guideId], references: [id], onDelete: SetNull)
  
  // Metadata
  source            String?        // "website", "email", "phone", "agent"
  ipAddress         String?
  userAgent         String?
  
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  
  @@map("bookings")
  @@index([status])
  @@index([paymentStatus])
  @@index([travelDate])
  @@index([email])
  @@index([tourId])
  @@index([vehicleId])
  @@index([guideId])
  @@index([createdAt])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  DEPOSIT_PAID
  PARTIALLY_PAID
  FULLY_PAID
  REFUNDED
  CANCELLED
}

// --------------- REVIEWS ---------------

model Review {
  id                String   @id @default(uuid())
  tourId            String
  tour              Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  
  // Reviewer Info
  customerName      String
  customerEmail     String?
  author            String?
  country           String?
  
  // Review Content
  rating            Int      // 1-5
  title             String
  comment           String   @db.Text
  content           String?  @db.Text
  safariPackage     String?
  
  // Metadata
  travelDate        DateTime?
  reviewDate        DateTime?
  helpful           Int      @default(0)
  verified          Boolean  @default(false)  // Actually took the tour
  isApproved        Boolean  @default(false)
  isFeatured        Boolean  @default(false)
  
  // Helpful votes
  helpfulCount      Int      @default(0)
  rawData           Json?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  
  @@map("reviews")
  @@index([tourId])
  @@index([isApproved])
  @@index([rating])
  @@index([isApproved, isFeatured])
}

// --------------- GUIDES ---------------

model Guide {
  id                String     @id @default(uuid())
  firstName         String
  lastName          String
  email             String     @unique
  phone             String
  
  // Professional Info
  languages         String[]   // Languages spoken
  specialties       String[]   // e.g., "Wildlife", "Birds", "Photography"
  experience        Int        // Years of experience
  bio               String?    @db.Text
  
  // Certifications
  certifications    String[]
  licenseNumber     String?
  
  // Profile
  avatar            String?
  rating            Float      @default(0)
  reviewCount       Int        @default(0)
  
  isActive          Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  // Relations
  bookings          Booking[]
  
  @@map("guides")
  @@index([isActive])
}

// --------------- CONTACT INQUIRIES ---------------

model ContactInquiry {
  id                String         @id @default(uuid())
  name              String
  email             String
  phone             String?
  country           String?
  subject           String
  message           String         @db.Text
  
  // Categorization
  inquiryType       InquiryType    @default(GENERAL)
  tourInterest      String?        // Tour slug they're interested in
  travelDate        DateTime?
  numberOfTravelers Int?
  
  // Status
  isRead            Boolean        @default(false)
  isReplied         Boolean        @default(false)
  repliedAt         DateTime?
  internalNotes     String?        @db.Text
  
  // Metadata
  source            String?        // "contact_form", "enquiry_form", "email"
  ipAddress         String?
  
  createdAt         DateTime       @default(now())
  
  @@map("contact_inquiries")
  @@index([inquiryType])
  @@index([isRead])
}

enum InquiryType {
  GENERAL
  TOUR_INQUIRY
  CUSTOM_SAFARI
  PRICING
  AVAILABILITY
  SUPPORT
  PARTNERSHIP
  FEEDBACK
}

// --------------- NEWSLETTER ---------------

model Newsletter {
  id                String     @id @default(uuid())
  email             String     @unique
  firstName         String?
  lastName          String?
  country           String?
  interests         String[]   // e.g., ["wildlife", "beach", "trekking"]
  
  isActive          Boolean    @default(true)
  subscribedAt      DateTime   @default(now())
  unsubscribedAt    DateTime?
  
  @@map("newsletters")
  @@index([isActive])
}

// --------------- BLOG ---------------

model BlogPost {
  id                String     @id @default(uuid())
  title             String
  slug              String     @unique
  subtitle          String?
  excerpt           String     @db.VarChar(500)
  content           String     @db.Text
  sections          Json?
  relatedPosts      Json?
  
  // Categorization
  category          String     // e.g., "Travel Tips", "Wildlife", "Destinations"
  tags              String[]
  
  // Author
  author            String
  authorBio         String?
  
  // Images
  featuredImage     String
  galleryImages     String[]
  
  // SEO
  metaTitle         String?
  metaDescription   String?
  
  // Engagement
  views             Int        @default(0)
  readingTime       Int        // Minutes
  
  // Status
  isPublished       Boolean    @default(false)
  publishedAt       DateTime?
  rawData           Json?
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  @@map("blog_posts")
  @@index([category])
  @@index([isPublished])
  @@index([publishedAt])
}

// --------------- FAQ ---------------

model FAQ {
  id                String     @id @default(uuid())
  question          String
  answer            String     @db.Text
  
  // Categorization
  category          String     // e.g., "Booking", "Safari", "Visa", "Health"
  displayOrder      Int        @default(0)
  
  // Status
  isActive          Boolean    @default(true)
  
  // Analytics
  viewCount         Int        @default(0)
  helpfulCount      Int        @default(0)
  notHelpfulCount   Int        @default(0)
  
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  
  @@map("faqs")
  @@index([category])
  @@index([isActive])
}

// --------------- MEDIA GALLERY ---------------

model Media {
  id                String     @id @default(uuid())
  filename          String
  originalName      String
  url               String
  thumbnailUrl      String?
  
  // Metadata
  mimeType          String
  fileSize          Int        // Bytes
  width             Int?
  height            Int?
  
  // Categorization
  category          String?    // "tours", "destinations", "blog", "gallery"
  tags              String[]
  altText           String?
  caption           String?
  
  createdAt         DateTime   @default(now())
  
  @@map("media")
  @@index([category])
}

// --------------- SETTINGS ---------------

model SiteSettings {
  id                String     @id @default(uuid())
  key               String     @unique
  value             String     @db.Text
  description       String?
  
  updatedAt         DateTime   @updatedAt
  
  @@map("site_settings")
}

// --------------- ADMIN USERS & RBAC ---------------

model AdminUser {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash     String
  firstName        String
  lastName        String
  avatar          String?
  
  // Profile
  phone           String?
  jobTitle        String?
  language       String?    @default("en")
  timezone       String?    @default("Africa/Dar_es_Salaam")
  
  // Role
  roleId          String
  role           AdminRole  @relation(fields: [roleId], references: [id])
  
  // Status
  isActive        Boolean    @default(true)
  lastLoginAt     DateTime?
  
  // Security
  failedAttempts  Int        @default(0)
  lockedUntil   DateTime?
  
  createdAt       DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  
  // Relations
  auditLogs       AdminAuditLog[]
  
  @@map("admin_users")
  @@index([roleId])
  @@index([isActive])
}

model AdminRole {
  id                String     @id @default(uuid())
  name              String     @unique  // "super_admin", "editor", "sales", "viewer"
  displayName       String
  description      String?
  
  // Permissions (JSON for flexibility)
  permissions      Json       @default("{}")
  
  // Hierarchy
  level           Int        @default(0)  // Higher = more权力
  
  isDefault       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  
  // Relations
  users           AdminUser[]
  
  @@map("admin_roles")
  @@index([level])
}

enum AdminPermission {
  // Tours
  TOURS_VIEW
  TOURS_CREATE
  TOURS_EDIT
  TOURS_DELETE
  
  // Destinations
  DESTINATIONS_VIEW
  DESTINATIONS_CREATE
  DESTINATIONS_EDIT
  DESTINATIONS_DELETE
  
  // Bookings
  BOOKINGS_VIEW
  BOOKINGS_EDIT
  BOOKINGS_CONFIRM
  BOOKINGS_CANCEL
  
  // Reviews
  REVIEWS_VIEW
  REVIEWS_EDIT
  REVIEWS_APPROVE
  
  // Inquiries
  INQUIRIES_VIEW
  INQUIRIES_REPLY
  
  // Users
  USERS_VIEW
  USERS_CREATE
  USERS_EDIT
  USERS_DELETE
  
  // Settings
  SETTINGS_VIEW
  SETTINGS_EDIT
  
  // Reports
  REPORTS_VIEW
  REPORTS_EXPORT
  
  // Analytics
  ANALYTICS_VIEW
}

// --------------- AUDIT LOGS ---------------

model AdminAuditLog {
  id                String     @id @default(uuid())
  userId            String
  user              AdminUser  @relation(fields: [userId], references: [id])
  
  // Action
  action            AdminAction
  entityType        String     // "tour", "booking", "user", etc.
  entityId         String
  
  // Details
  description      String     @db.Text
  metadata         Json?
  ipAddress        String?
  
  timestamp       DateTime   @default(now())
  
  @@map("admin_audit_logs")
  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
}

enum AdminAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  EXPORT
  BULK_UPDATE
  STATUS_CHANGE
}

// --------------- ADMIN NOTIFICATIONS ---------------

model AdminNotification {
  id                String     @id @default(uuid())
  type              NotificationType
  title             String
  message           String     @db.Text
  
  // Target
  targetRole        String?    // Specific role or null for all
  targetUserId     String?    // Or specific user
  
  // Status
  isRead            Boolean    @default(false)
  readAt           DateTime?
  
  // Action link
  actionUrl        String?
  
  expiresAt        DateTime?
  
  createdAt        DateTime   @default(now())
  
  @@map("admin_notifications")
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  // Bookings
  NEW_BOOKING
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  
  // Inquiries
  NEW_INQUIRY
  INQUIRY_REPLIED
  
  // Reviews
  NEW_REVIEW
  REVIEW_APPROVED
  
  // System
  SYSTEM_ALERT
  USER_ACTION
  REMINDER
}

// --------------- ANALYTICS ---------------

model PageView {
  id                String     @id @default(uuid())
  path              String     // URL path
  title             String?
  
  // Visitor Info
  ipAddress         String?
  userAgent         String?
  referrer          String?
  country           String?
  city              String?
  
  // Device Info
  device            String?    // "desktop", "mobile", "tablet"
  browser           String?
  os                String?
  
  // Session
  sessionId         String?
  timestamp         DateTime   @default(now())
  
  @@map("page_views")
  @@index([path])
  @@index([timestamp])
  @@index([sessionId])
}
